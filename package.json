{
  "name": "roundtable",
  "version": "0.12.0",
  "description": "Local-first React/TypeScript PWA for coordinating manual multi-model AI workflows with prompt provenance, Markdown handoff, import safety, and rollback.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "acceptance:walk": "node -e \"require('fs').mkdirSync('.tmp',{recursive:true})\" && esbuild scripts/acceptance-walk.ts --bundle --platform=node --format=cjs --external:none --outfile=.tmp/acceptance-walk.cjs && node --experimental-global-webcrypto .tmp/acceptance-walk.cjs",
    "verify": "npm run build && npm run acceptance:walk && npm audit --audit-level=high",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name roundtable",
    "preview:cloudflare": "npm run build && npx wrangler pages dev dist"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "keywords": [
    "react",
    "typescript",
    "vite",
    "pwa",
    "local-first",
    "ai-workflow",
    "llm",
    "prompt-engineering",
    "state-management",
    "markdown",
    "netlify",
    "portfolio",
    "cloudflare-pages",
    "cloudflare"
  ],
  "author": "Eric Harris",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  }
}
